{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && (fuser -k ${PORT:-8080}/tcp 2>/dev/null || true) && pnpm run start",
    "build": "vitest run src/__tests__/insurance-policy.test.ts src/__tests__/conversation-policy.test.ts src/__tests__/convenio-antiregressao.test.ts src/__tests__/prompt-builder-insurance-mode.test.ts && node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:e2e": "tsx src/tests/e2e-test.ts",
    "tutor:check": "tsx scripts/tutor-check.ts"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@swc/helpers": "^0.5.21",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integrations-openai-ai-server": "workspace:*",
    "axios": "^1.7.9",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "express-rate-limit": "^8.3.2",
    "google-auth-library": "^10.6.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.4",
    "pdfkit": "^0.18.0",
    "pino": "^9",
    "pino-http": "^10",
    "resend": "^6.10.0",
    "sharp": "^0.34.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "catalog:",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "^7.2.0",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "supertest": "^7.2.2",
    "thread-stream": "3.1.0",
    "tsx": "catalog:",
    "vitest": "^4.1.4"
  }
}
