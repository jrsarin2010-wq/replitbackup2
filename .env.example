# ============================================================
# OdontoFlow — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores.
# ============================================================

# ------------------------------------------------------------
# BANCO DE DADOS (obrigatório)
# ------------------------------------------------------------
# URL de conexão PostgreSQL
DATABASE_URL=postgresql://usuario:senha@localhost:5432/odontoflow

# ------------------------------------------------------------
# SEGURANÇA (obrigatório)
# ------------------------------------------------------------
# Chave secreta para assinar tokens JWT (mín. 32 caracteres aleatórios)
JWT_SECRET=troque-por-uma-chave-secreta-longa-e-aleatoria

# Chave para criptografia de dados sensíveis (ex: chaves de API dos tenants)
DATA_ENCRYPTION_KEY=troque-por-32-bytes-hex-aleatorio

# Chave para proteger chamadas internas do painel admin
ADMIN_API_KEY=troque-por-chave-admin-secreta

# ------------------------------------------------------------
# WHATSAPP — Evolution API (obrigatório para WhatsApp)
# ------------------------------------------------------------
# URL base da instância Evolution API (ex: https://api.evolution.com)
EVOLUTION_API_URL=https://n8n-evolution-api.mq6ww5.easypanel.host

# Chave global de autenticação da Evolution API
EVOLUTION_API_KEY=xfaa8GDyekJ5zIfz8XtQLgUsdFV8e5QK

# ------------------------------------------------------------
# OPENAI (obrigatório para IA conversacional)
# ------------------------------------------------------------
# No Replit, AI_INTEGRATIONS_OPENAI_* são providos automaticamente
# pela integração OpenAI do Replit.
# Fora do Replit, preencha com sua chave e a URL oficial.

# Alias compatível com SDKs OpenAI padrão (referência — o app usa as vars abaixo)
OPENAI_API_KEY=sk-...

# Chave usada internamente pelo servidor no boot (obrigatória — env.ts a valida)
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...

# URL base da API OpenAI (padrão: https://api.openai.com/v1)
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ------------------------------------------------------------
# WEBHOOKS (obrigatório para receber mensagens do WhatsApp)
# ------------------------------------------------------------
# Segredo para validar requisições de webhook
WEBHOOK_SECRET=troque-por-segredo-webhook

# URL base pública onde os webhooks serão recebidos
# Ex: https://seu-dominio.com  (sem barra final)
WEBHOOK_BASE_URL=https://seu-dominio.com

# ------------------------------------------------------------
# PAGAMENTOS — AbacatePay (opcional)
# ------------------------------------------------------------
# Chave de API para integração com AbacatePay
ABACATEPAY_API_KEY=

# ------------------------------------------------------------
# ÁUDIO / TTS — ElevenLabs (opcional)
# ------------------------------------------------------------
# Chave global de API ElevenLabs (fallback se o tenant não configurar a própria)
ELEVENLABS_API_KEY=

# ------------------------------------------------------------
# LIGAÇÕES IA — Vapi.ai (opcional)
# ------------------------------------------------------------
# Chave global de API Vapi (fallback se o tenant não configurar a própria)
# Crie sua conta em https://vapi.ai e acesse Dashboard > API Keys
VAPI_API_KEY=

# ------------------------------------------------------------
# E-MAIL SMTP (opcional — notificações e alertas)
# ------------------------------------------------------------
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_USER=usuario@exemplo.com
SMTP_PASS=senha-smtp
SMTP_FROM=noreply@exemplo.com

# ------------------------------------------------------------
# AMBIENTE (opcional — padrão: development)
# ------------------------------------------------------------
NODE_ENV=development

# Nível de log: trace | debug | info | warn | error
LOG_LEVEL=info

# ------------------------------------------------------------
# REPLIT (preenchido automaticamente pelo Replit — deixar vazio fora dele)
# ------------------------------------------------------------
# Domínio público do dev server no Replit (ex: abc123.riker.replit.dev)
REPLIT_DEV_DOMAIN=
